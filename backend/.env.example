# ============================================================
# Contoh environment variables untuk BACKEND.
# Salin ke ".env" (jangan commit .env) atau set di Coolify.
# ============================================================

# API key Google Gemini untuk fitur AI Assistant.
# Tanpa ini, fitur assistant nonaktif (backend tetap jalan normal).
GEMINI_API_KEY=

# Lokasi file SQLite. Untuk deploy dgn persistent volume, gunakan:
# DATABASE_PATH=/app/data/roadtierbers.db
# (kosongkan untuk default "roadtierbers.db" di folder backend)
DATABASE_PATH=/app/data/roadtierbers.db

# Set ke 1 untuk mengizinkan unduh yolov8n.pt dari internet jika model
# kendaraan tidak ditemukan. Default 0 (dimatikan) agar startup tak menggantung.
ALLOW_YOLO_DOWNLOAD=0
